// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  initials     String   @db.VarChar(3)
  passwordHash String
  role         Role     @default(MEMBER)
  avatarColor  String   @default("linear-gradient(135deg,#6c63ff,#ff6584)")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasksAssigned Task[]         @relation("TaskAssignee")
  tasksCreated  Task[]         @relation("TaskCreator")
  refreshTokens RefreshToken[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Column {
  id        String   @id @default(uuid())
  label     String
  color     String   @default("#6c63ff")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@map("columns")
}

model Sprint {
  id        String      @id @default(uuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tasks SprintTask[]
  goals GoalSprint[]

  @@map("sprints")
}

model SprintTask {
  id       String @id @default(uuid())
  sprintId String
  taskId   String
  order    Int    @default(0)
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([sprintId, taskId])
  @@map("sprint_tasks")
}

model Task {
  id          String     @id @default(uuid())
  taskKey     String     @unique
  title       String
  description String?
  status      String
  priority    Priority   @default(MEDIUM)
  tag         Tag        @default(FEATURE)
  progress    Int        @default(0)
  dueDate     DateTime?
  storyPoints   Int?
  recurrence    String?   // none|daily|weekly|monthly|custom
  recurrenceEnd DateTime?
  parentTaskId  String?
  createdAt     DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  columnId   String
  column     Column  @relation(fields: [columnId], references: [id])
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String
  creator    User    @relation("TaskCreator", fields: [creatorId], references: [id])

  comments     Comment[]
  subtasks     Subtask[]
  attachments  Attachment[]
  activityLogs ActivityLog[]
  sprints      SprintTask[]

  // Dependencies
  blockedBy    TaskDependency[] @relation("BlockedTask")
  blocks       TaskDependency[] @relation("BlockingTask")

  @@map("tasks")
}

model TaskDependency {
  id            String         @id @default(uuid())
  blockingTaskId String
  blockedTaskId  String
  type          DependencyType @default(BLOCKS)
  createdAt     DateTime       @default(now())

  blockingTask Task @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTask",  fields: [blockedTaskId],  references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
  @@map("task_dependencies")
}

model Subtask {
  id        String   @id @default(uuid())
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subtasks")
}

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  url          String
  publicId     String
  size         Int
  mimeType     String
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  createdAt    DateTime @default(now())

  @@map("attachments")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  mentions  CommentMention[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model CommentMention {
  id        String  @id @default(uuid())
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_mentions")
}

model ActivityLog {
  id         String       @id @default(uuid())
  taskId     String
  task       Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  action     ActivityAction
  field      String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime     @default(now())

  @@map("activity_logs")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Tag {
  FEATURE
  BUG
  DESIGN
  RESEARCH
  DOCS
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum DependencyType {
  BLOCKS
  BLOCKED_BY
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  COMMENT_ADDED
  TASK_MOVED
  SUBTASK_COMPLETED
  MENTIONED
  DEPENDENCY_ADDED
  SPRINT_STARTED
  SPRINT_COMPLETED
}

enum ActivityAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  SUBTASK_ADDED
  DEPENDENCY_ADDED
  ADDED_TO_SPRINT
  REMOVED_FROM_SPRINT
  PROGRESS_UPDATED
}

model AutomationRule {
  id          String   @id @default(uuid())
  name        String
  enabled     Boolean  @default(true)
  trigger     String   // e.g. "status_changed", "due_date_passed", "task_created", "priority_changed"
  triggerValue String? // e.g. the column id for status_changed
  action      String   // e.g. "assign_to", "set_priority", "move_to_column", "send_notification", "post_slack"
  actionValue String?  // e.g. userId, priority value, columnId
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("automation_rules")
}

model IntakeForm {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  columnId    String
  defaultPriority String @default("MEDIUM")
  defaultTag      String @default("FEATURE")
  defaultAssigneeId String?
  fields      Json     // array of { id, label, type, required }
  enabled     Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions IntakeSubmission[]

  @@map("intake_forms")
}

model IntakeSubmission {
  id         String   @id @default(uuid())
  formId     String
  form       IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  taskId     String?  // created task id
  data       Json     // submitted field values
  submitterEmail String?
  createdAt  DateTime @default(now())

  @@map("intake_submissions")
}

model SlackConfig {
  id          String   @id @default(uuid())
  webhookUrl  String
  channel     String?
  enabled     Boolean  @default(true)
  events      Json     // array of event types to notify
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("slack_configs")
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sprints GoalSprint[]

  @@map("goals")
}

model GoalSprint {
  id       String @id @default(uuid())
  goalId   String
  sprintId String
  goal     Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@unique([goalId, sprintId])
  @@map("goal_sprints")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
