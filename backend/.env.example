# ── Database (Railway PostgreSQL plugin auto-fills this) ──────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/projectflow"

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
JWT_SECRET="change-this-to-a-long-random-string-min-48-chars"
JWT_REFRESH_SECRET="change-this-to-another-long-random-string-min-48-chars"

# ── App ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── Brevo (Email) – FREE 300 emails/day, no credit card ───────────────────────
# Sign up: https://app.brevo.com → Settings → SMTP & API → SMTP tab
BREVO_SMTP_USER="your-brevo-login-email@example.com"
BREVO_SMTP_KEY="your-brevo-smtp-key-from-dashboard"
BREVO_FROM_EMAIL="noreply@yourdomain.com"

# ── Cloudinary (File uploads) – FREE 25GB storage + 25GB bandwidth/month ──────
# Sign up: https://cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
